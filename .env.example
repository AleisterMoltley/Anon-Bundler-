# === RPC ===
RPC_URL=https://your-jito-rpc.quicknode.com
MASTER_PRIVATE_KEY=

# === Launch Mode ===
MODE=pump                     # pump | raydium | multi

# === Token Config (nur für pump mode) ===
TOKEN_NAME=MyToken
TOKEN_SYMBOL=MTK
TOKEN_DESCRIPTION=My awesome token
TOKEN_IMAGE_URL=https://example.com/logo.png

# === Wallet / Bundle Config ===
NUM_WALLETS=20
SOL_PER_WALLET=0.28
BUNDLE_WALLETS_COUNT=4
JITO_TIP_LAMPORTS=950000
VANITY_PREFIX=
VANITY_TIMEOUT_SEC=30

# === Slippage ===
SLIPPAGE_BPS=500

# === Post-Launch ===
AUTO_MIGRATE=true
VOLUME_BOT_ENABLED=true
VOLUME_BUYS_PER_MIN=12
AUTO_SELL_PERCENT=35

# === Metadata ===
PINATA_JWT=

# === Security ===
WALLET_VAULT_PASSWORD=
DRY_RUN=true
