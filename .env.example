# === RPC ===
RPC_URL=https://your-rpc-endpoint.com
MASTER_PRIVATE_KEY=your_base58_private_key

# === Mode ===
# pump | raydium | multi
MODE=pump

# === Token Config ===
TOKEN_NAME=MyToken
TOKEN_SYMBOL=MTK
TOKEN_DESCRIPTION=A cool token
TOKEN_IMAGE_URL=https://example.com/image.png

# === Wallet Config ===
NUM_WALLETS=20
SOL_PER_WALLET=0.28
BUNDLE_WALLETS_COUNT=3
JITO_TIP_LAMPORTS=950000
VANITY_PREFIX=
VANITY_TIMEOUT_SEC=30

# === Creator Buy ===
CREATOR_BUY_SOL=0.5

# === Slippage (50-1000 bps, capped at 10%) ===
SLIPPAGE_BPS=500

# === Post-Launch ===
AUTO_MIGRATE=true
VOLUME_BOT_ENABLED=true
VOLUME_BUYS_PER_MIN=12
AUTO_SELL_PERCENT=35

# === Metadata ===
# Required for real launches — get from https://app.pinata.cloud
PINATA_JWT=

# === Security ===
# REQUIRED for real launches — encrypts wallet vault on disk
WALLET_VAULT_PASSWORD=
# Always start with dry run!
DRY_RUN=true
