# === RPC ===
RPC_URL=https://your-rpc-endpoint.com
MASTER_PRIVATE_KEY=your_base58_private_key

# === Mode ===
# pump | raydium | multi
MODE=pump

# === Token Config ===
TOKEN_NAME=MyToken
TOKEN_SYMBOL=MTK
TOKEN_DESCRIPTION=A cool token
TOKEN_IMAGE_URL=https://example.com/image.png

# === Wallet Config ===
NUM_WALLETS=20
SOL_PER_WALLET=0.28
# Max 3 (Jito bundle limit: 1 create + 3 buys + 1 tip = 5)
BUNDLE_WALLETS_COUNT=3
VANITY_PREFIX=
VANITY_TIMEOUT_SEC=30

# === Creator + Bundle Buy Amounts (SOL) ===
CREATOR_BUY_SOL=0.5
BUNDLE_BUY_MIN_SOL=0.09
BUNDLE_BUY_MAX_SOL=0.48

# === Jito Tip (dynamic via tip_floor API) ===
# Static fallback if tip_floor API fails (lamports)
JITO_TIP_LAMPORTS=1000000
# Percentile to target from landed bundles: 25 | 50 | 75 | 95 | 99
JITO_TIP_PERCENTILE=75
# Multiplier applied to the percentile value (e.g. 1.5 = 50% above)
JITO_TIP_MULTIPLIER=1.5
# Absolute cap on tip (lamports) to prevent runaway bids
JITO_TIP_MAX_LAMPORTS=5000000

# === Slippage (50-1000 bps, capped at 10%) ===
SLIPPAGE_BPS=500

# === Post-Launch ===
AUTO_MIGRATE=true
VOLUME_BOT_ENABLED=true
VOLUME_BUYS_PER_MIN=12
AUTO_SELL_PERCENT=35

# === Metadata ===
# Required for real launches — get from https://app.pinata.cloud
PINATA_JWT=

# === Jupiter API key (optional, unlocks higher rate limits — get from https://portal.jup.ag) ===
JUPITER_API_KEY=

# === Security ===
# REQUIRED for real launches — encrypts wallet vault on disk (AES-256-GCM)
WALLET_VAULT_PASSWORD=
# Always start with dry run!
DRY_RUN=true
